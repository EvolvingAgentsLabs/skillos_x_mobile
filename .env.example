# skillos_x_mobile — Environment Configuration

# --- OpenRouter API (required for Gemma 4 and Gemini backends) ---
# Cloud inference via OpenRouter. Supports function calling.
# Get your key at: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-...

# --- Anthropic API (required for Anthropic Claude backend) ---
# ANTHROPIC_API_KEY=sk-ant-...

# --- Backend Selection ---
# Agent backend: gemma4 | gemini | anthropic (default: gemma4)
# AGENT_BACKEND=gemma4

# Dream backend: gemma4 | gemini | anthropic (default: gemma4)
# DREAM_BACKEND=gemma4

# --- Model overrides (optional) ---
# AGENT_MODEL=google/gemma-4-26b-a4b-it
# ANTHROPIC_MODEL=claude-sonnet-4-20250514
# DREAM_MODEL=google/gemini-2.5-flash

# --- Memory & Traces ---
# MEMORY_DIR=./memory
# TRACES_DIR=./traces

# --- Web UI ---
# WS_PORT=9093
# HTTP_PORT=9094
